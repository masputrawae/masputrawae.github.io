---
import { Icon } from 'astro-icon/components'
import { SITE } from '../consts'
import { absURL } from '../utils/url'
import Container from './Container.astro'
---

<header class="border-b dark:border-neutral-700 md:hidden">
  <Container class:list="flex items-center justify-between min-h-14">
    <a href={absURL('/')} class="dark:text-white text-xl">
      {SITE.title}
    </a>

    <button class="dark:text-white flex items-center" data-sidebar="sidebar">
      <Icon name="bi:list" size={24} />
    </button>
  </Container>
</header>
