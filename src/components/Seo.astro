---
import { SITE } from '../../site.config'
import { type HTMLAttributes } from 'astro/types'
import { relURL, absURL } from '../lib/resolve-url'

export type Props = {
  title: string
  description: string
  ogImage?: string
  pubDate?: Date | null | undefined
  updatedDate?: Date | null | undefined
  keywords?: string[] | null | undefined
  pageType?: string

  extend?: {
    link: HTMLAttributes<'link'>[]
    meta: HTMLAttributes<'meta'>[]
  }
}

const {
  title,
  description,
  keywords,
  pubDate,
  updatedDate,
  extend,
  ogImage = relURL(`og-images/default.png`),
  pageType = 'website'
} = Astro.props

const { pathname } = Astro.url
const canonicalURL = absURL(pathname)

const isHome = pathname === import.meta.env.BASE_URL
const pTitle = title.length > 60 ? title.slice(0, 57) + '...' : title // page title
const mTitle = isHome ? SITE.title : `${pTitle} | ${SITE.title}` // meta title
---

<meta name="description" content={description} />
{SITE.author && <meta name="author" content={SITE.author.name} />}
{keywords && <meta name="keywords" content={keywords.join(', ')} />}

<link rel="canonical" href={canonicalURL} />
<link rel="sitemap" href={relURL('sitemap-index.xml')} />
<link rel="alternate" type="application/rss+xml" title={SITE.title} href={absURL('rss.xml')} />

<title>{mTitle}</title>

<!-- Open Graph -->
<meta property="og:title" content={mTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE.title} />
<meta property="og:locale" content={SITE.locale.replace('-', '_')} />
<meta property="og:type" content={pageType || 'website'} />

<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{
  pageType == 'article' && (
    <>
      {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
      {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
      {keywords && keywords.map((i) => <meta property="article:tag" content={i} />)}
    </>
  )
}

<!-- Twitter Card -->
<meta name="twitter:title" content={mTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:domain" content={Astro.site?.hostname} />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
<meta name="twitter:image" content={ogImage} />
{
  SITE.author?.twitterX && (
    <>
      <meta name="twitter:creator" content={SITE.author.twitterX} />
      <meta name="twitter:site" content={SITE.author.twitterX} />
    </>
  )
}

<!-- Extend (optional) -->
{extend?.link && extend.link.map((i) => <link {...i} />)}
{extend?.meta && extend.meta.map((i) => <link {...i} />)}

{SITE.favicons.map((i) => <link {...i} />)}
