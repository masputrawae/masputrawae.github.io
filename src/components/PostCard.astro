---
import { Picture } from 'astro:assets'
import { relURL } from '../lib/resolve-url.ts'
import { formattedDate } from '../lib/formatted-date'
import type { CollectionEntry } from 'astro:content'
import { Icon } from 'astro-icon/components'

type Props = {
  item: CollectionEntry<'content'>
}

const { item } = Astro.props
const { title, description, pubDate, cover, pinned } = item.data
const isoDate = pubDate.toISOString()
const humDate = formattedDate(pubDate)
---

<article
  class:list={[
    'group flex flex-col overflow-hidden rounded-lg border shadow-sm',
    'transition-all duration-300 hover:-translate-y-1 hover:shadow-lg',
    'border-neutral-200 bg-white',
    'dark:border-neutral-700 dark:bg-neutral-800'
  ]}
>
  <header
    class:list={[
      'aspect-video overflow-hidden bg-linear-to-bl',
      'from-violet-500 via-purple-400 to-violet-700'
    ]}
  >
    {
      cover && (
        <Picture
          src={cover}
          alt={title}
          width={800}
          height={600}
          quality={'max'}
          formats={['webp', 'avif']}
          class="h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-105"
        />
      )
    }
  </header>
  <section class="flex flex-1 flex-col gap-2 p-4">
    <h3 class:list={['line-clamp-2 text-lg font-semibold', 'text-neutral-900', 'dark:text-white']}>
      {pinned && <Icon name="bi:stars" size={24} class="inline-flex items-center text-amber-400" />}
      <a href={relURL(item.id)}>{title}</a>
    </h3>
    <p class:list={['line-clamp-2 text-sm', 'text-neutral-600', 'dark:text-neutral-400']}>
      {description}
    </p>
  </section>
  <footer
    class:list={[
      'flex items-center justify-between border-t px-4 py-3 text-xs',
      'border-neutral-100 text-neutral-500',
      'dark:border-neutral-700 dark:text-neutral-400'
    ]}
  >
    <time datetime={isoDate}>{humDate}</time>
    <a
      href={relURL(item.id)}
      class:list={[
        'inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium transition-colors',
        'bg-neutral-900 text-white hover:bg-neutral-700'
      ]}
    >
      <Icon name="bi:eye" />
      <span>Read</span>
      <span class="sr-only">{title}</span>
    </a>
  </footer>
</article>
