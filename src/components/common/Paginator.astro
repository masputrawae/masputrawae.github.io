---
import type { Page } from "astro"

type Props = {
  page: Page
}

const { page } = Astro.props
---

{
  page.lastPage !== 1 && (
    <nav class="flex items-center justify-center divide-x divide-neutral-200 text-sm dark:divide-neutral-800 [&_a]:px-4 [&_span]:px-4">
      <a
        href={page.url.first || Astro.url.pathname}
        {...(!page.url.first && {
          "aria-current": "page",
          "aria-disabled": "true",
          style: "cursor: not-allowed",
        })}
      >
        First
      </a>
      <a
        href={page.url.prev || Astro.url.pathname}
        {...(!page.url.prev
          ? {
              "aria-current": "page",
              "aria-disabled": "true",
              style: "cursor: not-allowed",
            }
          : { rel: "prev" })}
      >
        Prev
      </a>
      <span aria-current="page">{page.currentPage}</span>
      <a
        href={page.url.next || Astro.url.pathname}
        {...(!page.url.next
          ? {
              "aria-current": "page",
              "aria-disabled": "true",
              style: "cursor: not-allowed",
            }
          : { rel: "next" })}
      >
        Next
      </a>
      <a
        href={page.url.last || Astro.url.pathname}
        {...(!page.url.last && {
          "aria-current": "page",
          "aria-disabled": "true",
          style: "cursor: not-allowed",
        })}
      >
        Last
      </a>
    </nav>
  )
}
