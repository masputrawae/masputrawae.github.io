---
import type { HTMLAttributes } from "astro/types"

interface Props extends HTMLAttributes<"a"> {
  variant?: "base" | "primary"
}

const { href, variant = "base", class: className, ...rest } = Astro.props

const variants = {
  primary:
    "border-transparent bg-neutral-900 text-white dark:bg-neutral-100 dark:text-black",
  base: "border-neutral-300 dark:border-neutral-700",
}
---

<a
  href={href}
  class:list={["border px-4 py-2 font-bold no-underline", variants[variant], className]}
  {...rest}
>
  <slot />
</a>
