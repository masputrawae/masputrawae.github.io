---
import type { HTMLAttributes } from 'astro/types'
import { SITE } from '../consts'

interface Attr extends HTMLAttributes<'time'> {
  date: Date
}

type Props = Attr

const { date, datetime, ...attr } = Astro.props
---

<time datetime={date.toISOString()} {...attr}>
  {
    date.toLocaleDateString(SITE.languageCode, {
      year: 'numeric',
      month: 'short',
      day: 'numeric'
    })
  }
</time>
