---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Content as Markdown } from '../components/page/AboutContent.md'

const title = 'Putra Jaya'
import thumbnail from '../../public/thumbnail.webp'
import { Image } from 'astro:assets'

const meta = {
  title: 'About',
	description:
		'Saya belajar pemrograman secara otodidak karena sudah lama putus sekolah dan tidak punya akses ke pendidikan formal. Tidak ada motivasi besar atau tujuan mulia—saya cuma ingin mengisi hari-hari dengan sesuatu yang berarti, dan belajar hal baru setiap hari terasa lebih baik daripada tidak belajar apa-apa sama sekali.'
}
---

<BaseLayout meta={meta}>
	<header class="typography prose-em:not-italic">
		<picture class="mb-10 block aspect-video overflow-hidden rounded-2xl shadow-md shadow-black">
			<Image
				src={thumbnail}
				alt={title}
				width={1920}
				height={1080}
				layout={`constrained`}
				fit={`fill`}
			/>
		</picture>
		<Markdown />
	</header>
</BaseLayout>
