views:
  - type: cards
    name: Content
    filters:
      and:
        - file.inFolder("content")
    order:
      - title
      - description
      - tags
    sort:
      - property: cover
        direction: ASC
      - property: pubDate
        direction: DESC
    imageAspectRatio: 0.6
    image: note.cover
    cardSize: 340
